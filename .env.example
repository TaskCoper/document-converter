# Fine-grained personal access token, scoped to a single repo
# with "Contents: Read and write" permission only.
# Note: these VITE_* vars are bundled into client JS — they are NOT secret.
VITE_GH_TOKEN =
VITE_GH_OWNER =
VITE_GH_REPO =
VITE_GH_BRANCH =
# Subdirectory the UI is scoped to. All CRUD is confined to this path.
VITE_GH_ROOT_DIR = 
